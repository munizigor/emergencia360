    <bpmn:textAnnotation id="TextAnnotation_01pfwmr">
      <bpmn:text>Vamos transferir sua ligação para uma avaliação médica. Permaneça na linha que um atendente do SAMU irá lhe atender</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1ehjuza" associationDirection="None" sourceRef="Activity_0hbemo1" targetRef="TextAnnotation_01pfwmr" />
    <bpmn:textAnnotation id="TextAnnotation_11kory6">
      <bpmn:text>O modo assistido permite que o atendente acompanhe a ligação e se certifique que ela foi atendida</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_181o2w8" associationDirection="None" sourceRef="Activity_0gb9wbm" targetRef="TextAnnotation_11kory6" />
    <bpmn:textAnnotation id="TextAnnotation_00k21xx">
      <bpmn:text>- Falha técnica
- Falta de atendentes</bpmn:text>
    </bpmn:textAnnotation>
