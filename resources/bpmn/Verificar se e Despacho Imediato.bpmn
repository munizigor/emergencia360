    <bpmn:textAnnotation id="TextAnnotation_1j4sxbn">
      <bpmn:text>ART. 7º, IV da Portaria 040:

a. parada respiratória;
b. parada cardiorrespiratória;
c. obstrução de vias aéreas por corpo estranho;
d. situações de trauma;
e. composição do trem de socorro;</bpmn:text>
